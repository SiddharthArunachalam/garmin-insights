# Garmin Connect credentials
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=your_garmin_password

# Gemini API key — get one free at https://aistudio.google.com (no credit card needed)
GEMINI_API_KEY=AIza...

# PostgreSQL connection string (Supabase) — leave blank to use local SQLite
# Get this from: Supabase project → Settings → Database → Connection string → URI
# Use the "Session mode" pooler URL for Streamlit Cloud:
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
